# -----------------------------------------------------------------------------
# Base URL of the application
# -----------------------------------------------------------------------------
VITE_BASE_URL='https://classgamify.example'

# -----------------------------------------------------------------------------
# Cloudflare Token
# Required for deploys and for Cloudflare Email when mail.provider='cloudflare'.
# For Cloudflare Email, the token needs Email Send permission.
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=''
CLOUDFLARE_API_TOKEN=''

# -----------------------------------------------------------------------------
# Database (D1)
# -----------------------------------------------------------------------------
CLOUDFLARE_DATABASE_ID=''

# -----------------------------------------------------------------------------
# Auth (Better Auth)
# Generate a secret key: `pnpm dlx @better-auth/cli@latest secret`
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=''
# -----------------------------------------------------------------------------
# Google OAuth
# Callback URL: https://classgamify.example/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''

# -----------------------------------------------------------------------------
# Payment Provider ('stripe' | 'creem' | '' to disable payment)
# -----------------------------------------------------------------------------
VITE_PAYMENT_PROVIDER=''

# -----------------------------------------------------------------------------
# Payment (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=''
STRIPE_WEBHOOK_SECRET=''
VITE_STRIPE_PRICE_PRO_MONTHLY=''
VITE_STRIPE_PRICE_PRO_YEARLY=''
VITE_STRIPE_PRICE_LIFETIME=''

# -----------------------------------------------------------------------------
# Payment (Creem)
# -----------------------------------------------------------------------------
CREEM_DEBUG='true'
CREEM_API_KEY=''
CREEM_WEBHOOK_SECRET=''
VITE_CREEM_PRODUCT_PRO_MONTHLY=''
VITE_CREEM_PRODUCT_PRO_YEARLY=''
VITE_CREEM_PRODUCT_LIFETIME=''

# -----------------------------------------------------------------------------
# Mail (Resend)
# Only needed when mail.provider='resend' in src/config/website.ts.
# -----------------------------------------------------------------------------
RESEND_API_KEY=''

# -----------------------------------------------------------------------------
# Newsletter (Beehiiv)
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=''
BEEHIIV_PUBLICATION_ID=''

# -----------------------------------------------------------------------------
# Notification (Discord and Feishu)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=''
FEISHU_WEBHOOK_URL=''

# -----------------------------------------------------------------------------
# Chatbot (Crisp Chat)
# -----------------------------------------------------------------------------
VITE_CRISP_WEBSITE_ID=''

# -----------------------------------------------------------------------------
# Analytics (Plausible)
# -----------------------------------------------------------------------------
VITE_PLAUSIBLE_SCRIPT=''
# -----------------------------------------------------------------------------
# Analytics (Google)
# -----------------------------------------------------------------------------
VITE_GOOGLE_ANALYTICS_ID=''
# -----------------------------------------------------------------------------
# Analytics (Umami)
# -----------------------------------------------------------------------------
VITE_UMAMI_SCRIPT='https://cloud.umami.is/script.js'
VITE_UMAMI_WEBSITE_ID=''
# -----------------------------------------------------------------------------
# Analytics (Clarity)
# -----------------------------------------------------------------------------
VITE_CLARITY_PROJECT_ID=''

# -----------------------------------------------------------------------------
# Fal
# -----------------------------------------------------------------------------
FAL_KEY=''
