# -----------------------------------------------------------------------------
# Production environment template
#
# Cloudflare Git integration owns production builds and deploys for
# ClassGamify. Set VITE_BASE_URL in the Cloudflare project build environment.
# Set runtime secrets such as BETTER_AUTH_SECRET, OAuth keys, mail keys,
# payment keys, webhook secrets, and Workers AI credentials in Cloudflare
# Worker secrets.
#
# For local manual secret sync only, copy this file to .env.production and run:
#   pnpm sync-worker-secrets
# -----------------------------------------------------------------------------
VITE_BASE_URL='https://classgamify.example'
CLOUDFLARE_ACCOUNT_ID=''
CLOUDFLARE_API_TOKEN=''
CLOUDFLARE_DATABASE_ID=''
BETTER_AUTH_SECRET=''

# -----------------------------------------------------------------------------
# Optional auth providers
# Google callback URL: https://classgamify.example/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''

# -----------------------------------------------------------------------------
# Payment Provider ('stripe' | 'creem' | '' to disable payment)
# -----------------------------------------------------------------------------
VITE_PAYMENT_PROVIDER=''

# -----------------------------------------------------------------------------
# Payment (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=''
STRIPE_WEBHOOK_SECRET=''
VITE_STRIPE_PRICE_PRO_MONTHLY=''
VITE_STRIPE_PRICE_PRO_YEARLY=''
VITE_STRIPE_PRICE_LIFETIME=''

# -----------------------------------------------------------------------------
# Payment (Creem)
# -----------------------------------------------------------------------------
CREEM_DEBUG='true'
CREEM_API_KEY=''
CREEM_WEBHOOK_SECRET=''
VITE_CREEM_PRODUCT_PRO_MONTHLY=''
VITE_CREEM_PRODUCT_PRO_YEARLY=''
VITE_CREEM_PRODUCT_LIFETIME=''

# -----------------------------------------------------------------------------
# Mail (Resend)
# Only needed when mail.provider='resend' in src/config/website.ts.
# -----------------------------------------------------------------------------
RESEND_API_KEY=''

# -----------------------------------------------------------------------------
# Newsletter (Beehiiv)
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=''
BEEHIIV_PUBLICATION_ID=''

# -----------------------------------------------------------------------------
# Notification (Discord and Feishu)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=''
FEISHU_WEBHOOK_URL=''

# -----------------------------------------------------------------------------
# Chatbot (Crisp Chat)
# -----------------------------------------------------------------------------
VITE_CRISP_WEBSITE_ID=''

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
VITE_PLAUSIBLE_SCRIPT=''
VITE_GOOGLE_ANALYTICS_ID=''
VITE_UMAMI_SCRIPT='https://cloud.umami.is/script.js'
VITE_UMAMI_WEBSITE_ID=''
VITE_CLARITY_PROJECT_ID=''

# -----------------------------------------------------------------------------
# AI activity drafts (Cloudflare Workers AI)
# Uses CLOUDFLARE_ACCOUNT_ID and CLOUDFLARE_API_TOKEN above.
# -----------------------------------------------------------------------------
