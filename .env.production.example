# -----------------------------------------------------------------------------
# Production environment template
#
# GitHub Actions deployment needs VITE_BASE_URL, CLOUDFLARE_ACCOUNT_ID,
# CLOUDFLARE_API_TOKEN, and CLOUDFLARE_DATABASE_ID as repository secrets.
# Cloudflare Email also uses CLOUDFLARE_ACCOUNT_ID and CLOUDFLARE_API_TOKEN
# at Worker runtime when mail.provider='cloudflare'.
#
# Cloudflare Worker runtime secrets are set with:
#   pnpm sync-worker-secrets
# after copying this file to .env.production and filling in real values.
# -----------------------------------------------------------------------------
VITE_BASE_URL='https://getlangstudy.com'
CLOUDFLARE_ACCOUNT_ID=''
CLOUDFLARE_API_TOKEN=''
CLOUDFLARE_DATABASE_ID='885df2bc-1419-458c-b8b6-0821eddfb399'
BETTER_AUTH_SECRET=''

# -----------------------------------------------------------------------------
# Optional auth providers
# Google callback URL: https://getlangstudy.com/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''

# -----------------------------------------------------------------------------
# Payment Provider ('stripe' | 'creem' | '' to disable payment)
# -----------------------------------------------------------------------------
VITE_PAYMENT_PROVIDER=''

# -----------------------------------------------------------------------------
# Payment (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=''
STRIPE_WEBHOOK_SECRET=''
VITE_STRIPE_PRICE_PRO_MONTHLY=''
VITE_STRIPE_PRICE_PRO_YEARLY=''
VITE_STRIPE_PRICE_LIFETIME=''

# -----------------------------------------------------------------------------
# Payment (Creem)
# -----------------------------------------------------------------------------
CREEM_DEBUG='true'
CREEM_API_KEY=''
CREEM_WEBHOOK_SECRET=''
VITE_CREEM_PRODUCT_PRO_MONTHLY=''
VITE_CREEM_PRODUCT_PRO_YEARLY=''
VITE_CREEM_PRODUCT_LIFETIME=''

# -----------------------------------------------------------------------------
# Mail (Resend)
# Only needed when mail.provider='resend' in src/config/website.ts.
# -----------------------------------------------------------------------------
RESEND_API_KEY=''

# -----------------------------------------------------------------------------
# Newsletter (Beehiiv)
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=''
BEEHIIV_PUBLICATION_ID=''

# -----------------------------------------------------------------------------
# Notification (Discord and Feishu)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=''
FEISHU_WEBHOOK_URL=''

# -----------------------------------------------------------------------------
# Chatbot (Crisp Chat)
# -----------------------------------------------------------------------------
VITE_CRISP_WEBSITE_ID=''

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
VITE_PLAUSIBLE_SCRIPT=''
VITE_GOOGLE_ANALYTICS_ID=''
VITE_UMAMI_SCRIPT='https://cloud.umami.is/script.js'
VITE_UMAMI_WEBSITE_ID='671589e6-7f44-41d5-a603-7ffabca5cfc0'
VITE_CLARITY_PROJECT_ID='x87hl5xy62'

# -----------------------------------------------------------------------------
# AI image generation (fal.ai)
# -----------------------------------------------------------------------------
FAL_KEY=''
